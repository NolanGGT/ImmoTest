# Production environment — copy to .env and fill in real values
# NEVER commit the .env file to git

NODE_ENV=production
PORT=3000

# ── Database (Supabase) ────────────────────────────────────────────────────────
# Same project as dev; use the pooler URL for DATABASE_URL in prod if needed
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:PASSWORD@db.XXXX.supabase.co:5432/postgres

# ── JWT — generate NEW secrets for prod (different from dev!) ─────────────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=GENERER_UN_NOUVEAU_SECRET_PROD
JWT_REFRESH_SECRET=GENERER_UN_AUTRE_SECRET_PROD

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe LIVE (not test!) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ── URLs production ───────────────────────────────────────────────────────────
WEB_URL=https://immosafe.fr
API_URL=https://api.immosafe.fr

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@immosafe.fr
